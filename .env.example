# Inference backend for /api/chat and the playground.
# Any OpenAI-compatible server works: mlx_lm.server (local), vLLM (cloud), …
# Leave unset to keep the playground in demo mode.

# Local Mac (ml/serve.sh):
INFERENCE_BASE_URL=http://localhost:8080/v1
INFERENCE_MODEL_ID=astra

# Hosted endpoints only:
# INFERENCE_API_KEY=

# Supabase (auth + database). Leave unset to run with auth disabled (demo mode).
# Project settings → API: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only admin key — never expose to the browser. Optional for now.
# SUPABASE_SERVICE_ROLE_KEY=

# GitHub OAuth App — gives Ren Code repository access (separate from sign-in).
# Create at: https://github.com/settings/developers
# Authorization callback URL: <your-origin>/api/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Secret used to encrypt the GitHub session cookie. Generate with:
#   openssl rand -hex 32
# Falls back to GITHUB_CLIENT_SECRET if unset, but a dedicated secret is preferred.
GITHUB_SESSION_SECRET=
# Optional — OAuth scopes to request (default: repo workflow read:user user:email)
#   repo        — full control of the user's repositories (create, push, manage)
#   workflow    — required to push files under .github/workflows
#   delete_repo — add this if you want Ren to be able to delete repos too
# GITHUB_OAUTH_SCOPES=repo workflow read:user user:email
