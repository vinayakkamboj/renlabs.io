# ── Astra model ─────────────────────────────────────────────────────────────
# Powers the build agent (/api/builder) and the Astra chatbot (/api/astra).
# Fireworks AI is the primary provider (direct GPU infrastructure, SLA-backed).
# Claude (Anthropic) is the fallback when Fireworks is unreachable.
#
# 1) Fireworks AI (primary). Get a key at https://fireworks.ai/account/api-keys
#    Server-only — never NEXT_PUBLIC_.
FIREWORKS_API_KEY=
# Fireworks model slug. GLM 5.2 on serverless pay-per-token. This exact slug is
# the one available serverless — the -fp8 variant needs a dedicated deployment
# and returns "model not found / not deployed" if used serverless.
FIREWORKS_MODEL=accounts/fireworks/models/glm-5p2
# Optional — design/orchestration phase. OFF by default for reliability: a first
# build streams the app directly, which gives the build the full time budget and
# avoids empty results on complex prompts. Set to 1 to enable a live architecture
# plan before the build (best on higher-tier hosting with longer function limits).
# ASTRA_DESIGN_PHASE=1
# Optional — per-pass output token ceiling for BIG builds (quick edits are
# fixed at 8000). Generous by default (16000) because GLM's hidden reasoning
# tokens count against it; time safety comes from the streaming pass deadline
# below, not from squeezing tokens.
# ASTRA_MAX_OUTPUT_TOKENS=16000
# Optional — per-pass TIME budget in ms. Generation is cut at this deadline,
# complete files are salvaged, and the next pass continues the build. Kept
# close to the platform's ~300s function limit (default 265000) because GLM
# reasons in one block before emitting any content — a tight budget can
# expire before a complex prompt ever starts writing files. Lower this only
# if your maxDuration is below 300s.
# ASTRA_PASS_TIME_BUDGET_MS=265000
# Optional — lighter/faster model for the design-phase plan. If unset, planning
# reuses FIREWORKS_MODEL at low reasoning effort. Time-boxed either way.
# Example: accounts/fireworks/models/glm-4p6
# FIREWORKS_PLANNING_MODEL=
#
# 2) Claude fallback. If FIREWORKS_API_KEY is unset, Astra is served by Claude.
#    Server-only — never NEXT_PUBLIC_.
ANTHROPIC_API_KEY=
# Claude model id to use for the fallback (vision-capable, supports image uploads).
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Ambient agents (looping agents) ─────────────────────────────────────────
# Two schedulers drive the loops; both claim agents atomically so they never
# double-run the same agent:
#   • /api/agents/tick — pinged every minute by the workspace while it's open.
#     No secret needed (user-session auth). This is the primary cadence.
#   • /api/cron/agents — platform cron for when every tab is closed.
#     vercel.json ships a DAILY schedule (the most Vercel Hobby allows — a
#     tighter one blocks the deploy). On Vercel Pro, change vercel.json's
#     schedule to "*/5 * * * *" for true always-on loops.
# Secret required on the cron endpoint — Vercel sends it automatically as a
# Bearer token when CRON_SECRET is set. Generate with: openssl rand -hex 32
# If unset, the endpoint is open — set this in any deployed environment.
CRON_SECRET=

# ── Legacy playground inference (optional) ──────────────────────────────────
# The /playground page can stream from any OpenAI-compatible server.
# INFERENCE_BASE_URL=http://localhost:8080/v1
# INFERENCE_MODEL_ID=astra
# INFERENCE_API_KEY=

# Supabase (auth + database). Leave unset to run with auth disabled (demo mode).
# Project settings → API: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only admin key — never expose to the browser. Required for the admin
# panel (/admin) to read platform-wide data. NEVER prefix with NEXT_PUBLIC_.
# SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated allowlist of emails granted access to the admin panel (/admin).
# A user is also an admin if their profiles.role = 'admin'.
# ADMIN_EMAILS=you@renlabs.io

# GitHub repository access (separate from sign-in). Ren supports two modes:
#
#   • GitHub App  (recommended — see GITHUB_APP_SETUP.md). Set GITHUB_APP_SLUG
#     plus the app's Client ID / secret. Users install the app and Ren gets
#     per-repo access with high rate limits and short-lived tokens.
#   • OAuth App   (simpler). Leave GITHUB_APP_SLUG unset; the app uses the
#     classic authorize+scope flow.
#
# In BOTH modes, set GITHUB_CLIENT_ID / GITHUB_CLIENT_SECRET to the app's
# OAuth credentials, and the callback URL to <your-origin>/api/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# GitHub App slug — the name in your app's public URL
# (github.com/apps/<slug>). Setting this enables GitHub App mode.
# Example: ren-coding-agent
GITHUB_APP_SLUG=
# Canonical app URL — REQUIRED on Vercel so the OAuth redirect_uri is always
# your production domain, not a preview URL or localhost.
# Example: https://ren-ai-six.vercel.app
NEXT_PUBLIC_APP_URL=
# Secret used to encrypt the GitHub session cookie. Generate with:
#   openssl rand -hex 32
# Falls back to GITHUB_CLIENT_SECRET if unset, but a dedicated secret is preferred.
GITHUB_SESSION_SECRET=
# Optional — OAuth App scopes (ignored in GitHub App mode; permissions come from
# the app config instead). Default: repo workflow read:user user:email
# GITHUB_OAUTH_SCOPES=repo workflow read:user user:email

# ─── SMTP for admin OTP email (sent directly from the backend) ───────────────
# Copy these from your existing Supabase SMTP settings — same credentials.
# Used by /api/auth/send-otp to deliver the branded 6-digit sign-in code.
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=your_smtp_password_or_api_key
# SMTP_FROM=Ren Labs <noreply@renlabs.io>

# ─── Private beta access + billing ────────────────────────────────────────────
# Ren is allowlist-only: @renlabs.io accounts and vinayakkamboj01@gmail.com are
# always allowed (baked into src/lib/auth/allowlist.ts). Extend the list here
# without a code change (comma-separated):
# REN_ALLOWED_EMAILS=friend@example.com,tester@example.com
# REN_ALLOWED_DOMAINS=partner.com

# Billing kill-switch. Unset/0 = generation is FREE (no credits charged, nobody
# blocked on balance). Set to 1 the moment payments are live to enforce the
# full metered credit system.
# REN_BILLING_ENFORCED=1
