# Inference backend for /api/chat and the playground.
# Any OpenAI-compatible server works: mlx_lm.server (local), vLLM (cloud), …
# Leave unset to keep the playground in demo mode.

# Local Mac (ml/serve.sh):
INFERENCE_BASE_URL=http://localhost:8080/v1
INFERENCE_MODEL_ID=astra

# Hosted endpoints only:
# INFERENCE_API_KEY=

# Supabase (auth + database). Leave unset to run with auth disabled (demo mode).
# Project settings → API: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only admin key — never expose to the browser. Required for the admin
# panel (/admin) to read platform-wide data. NEVER prefix with NEXT_PUBLIC_.
# SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated allowlist of emails granted access to the admin panel (/admin).
# A user is also an admin if their profiles.role = 'admin'.
# ADMIN_EMAILS=you@renlabs.io

# GitHub repository access (separate from sign-in). Ren supports two modes:
#
#   • GitHub App  (recommended — see GITHUB_APP_SETUP.md). Set GITHUB_APP_SLUG
#     plus the app's Client ID / secret. Users install the app and Ren gets
#     per-repo access with high rate limits and short-lived tokens.
#   • OAuth App   (simpler). Leave GITHUB_APP_SLUG unset; the app uses the
#     classic authorize+scope flow.
#
# In BOTH modes, set GITHUB_CLIENT_ID / GITHUB_CLIENT_SECRET to the app's
# OAuth credentials, and the callback URL to <your-origin>/api/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# GitHub App slug — the name in your app's public URL
# (github.com/apps/<slug>). Setting this enables GitHub App mode.
# Example: ren-coding-agent
GITHUB_APP_SLUG=
# Canonical app URL — REQUIRED on Vercel so the OAuth redirect_uri is always
# your production domain, not a preview URL or localhost.
# Example: https://ren-ai-six.vercel.app
NEXT_PUBLIC_APP_URL=
# Secret used to encrypt the GitHub session cookie. Generate with:
#   openssl rand -hex 32
# Falls back to GITHUB_CLIENT_SECRET if unset, but a dedicated secret is preferred.
GITHUB_SESSION_SECRET=
# Optional — OAuth App scopes (ignored in GitHub App mode; permissions come from
# the app config instead). Default: repo workflow read:user user:email
# GITHUB_OAUTH_SCOPES=repo workflow read:user user:email
